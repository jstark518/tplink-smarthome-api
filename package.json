{
  "name": "tplink-smarthome-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @jstark/tplink-smarthome-api and @jstark/tplink-smarthome-crypto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/jstark518/tplink-smarthome-api.git"
  },
  "workspaces": [
    "packages/tplink-smarthome-crypto",
    "packages/tplink-smarthome-api"
  ],
  "scripts": {
    "build": "npm run build -w @jstark/tplink-smarthome-crypto && npm run build -w @jstark/tplink-smarthome-api",
    "lint": "npm run lint --workspaces",
    "docs": "npm run docs -w @jstark/tplink-smarthome-api",
    "test": "npm run test --workspaces",
    "test:ci": "npm run test:ci --workspaces",
    "spellcheck": "npm run spellcheck --workspaces",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@eslint/js": "^9.39.5",
    "@gmrchk/cli-testing-library": "^0.1.2",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/promise-queue": "^2.2.3",
    "@types/sinon-chai": "^4.0.0",
    "c8": "^11.0.0",
    "chai": "^5.3.3",
    "chai-as-promised": "^8.0.2",
    "cross-env": "^10.1.0",
    "cspell": "^8.0.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-pretty": "^7.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.7.0",
    "mocha": "^11.7.6",
    "prettier": "^3.1.0",
    "rimraf": "^6.1.3",
    "sinon": "^22.0.0",
    "sinon-chai": "^4.0.1",
    "tplink-smarthome-simulator": "^5.0.1",
    "ts-essentials": "^9.4.1",
    "tsx": "^4.23.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-no-inherit": "^1.6.1",
    "typescript": "5.2.2",
    "typescript-eslint": "^8.63.0"
  },
  "engines": {
    "node": ">=22"
  }
}
