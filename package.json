{
  "name": "@jstark/tplink-smarthome-api",
  "version": "6.0.0",
  "description": "TP-Link Smart Home API",
  "keywords": [
    "tplink",
    "kasa",
    "home",
    "smartplug",
    "smartswitch",
    "smartbulb",
    "api"
  ],
  "bugs": {
    "url": "https://github.com/jstark518/tplink-smarthome-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/jstark518/tplink-smarthome-api.git"
  },
  "license": "MIT",
  "author": "Patrick Seal",
  "type": "commonjs",
  "main": "./lib/index.js",
  "bin": {
    "tplink-smarthome-api": "lib/cli.js"
  },
  "files": [
    "lib"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prebuild": "npm run clean",
    "build": "tsc --project tsconfig.source.json",
    "clean": "rimraf lib/ build/",
    "cli": "tsx src/cli.ts",
    "docs": "typedoc --tsconfig tsconfig.source.json",
    "lint": "eslint . --format=pretty && tsc --noEmit",
    "prepare": "npm run build",
    "release": "release-it",
    "spellcheck": "cspell '{examples,src,test}/**/*' *.md",
    "pretest": "npm run lint && npm run build",
    "test": "npm run test:only",
    "test:ci": "npm run test:only",
    "test:only": "cross-env NODE_ENV=test NODE_OPTIONS=\"--import tsx\" c8 mocha --color",
    "lint:fix": "eslint . --format=pretty --fix"
  },
  "dependencies": {
    "@commander-js/extra-typings": "~11.1.0",
    "commander": "~11.1.0",
    "loglevel": "^1.8.1",
    "promise-queue": "^2.2.5",
    "tplink-smarthome-crypto": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@gmrchk/cli-testing-library": "^0.1.2",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.43",
    "@types/promise-queue": "^2.2.3",
    "@types/sinon-chai": "^4.0.0",
    "c8": "^10.1.3",
    "chai": "^5.3.3",
    "chai-as-promised": "^8.0.2",
    "cross-env": "^7.0.3",
    "cspell": "^8.0.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-pretty": "^7.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^15.15.0",
    "mocha": "^11.7.6",
    "prettier": "^3.1.0",
    "release-it": "^20.2.1",
    "rimraf": "^5.0.10",
    "sinon": "^22.0.0",
    "sinon-chai": "^4.0.1",
    "tplink-smarthome-simulator": "^5.0.1",
    "ts-essentials": "^9.4.1",
    "tsx": "^4.23.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-no-inherit": "^1.6.1",
    "typescript": "5.2.2",
    "typescript-eslint": "^8.63.0"
  },
  "engines": {
    "node": ">=22"
  }
}
